{
  "manifest_version": 3,
  "name": "AuraLock Snitch",
  "version": "1.0",
  "description": "Scans the active browser tab for videos and sends frames to the AuraLock Vault.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AuraLock Status"
  }
}
